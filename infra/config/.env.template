# ScholarOS local-first environment template

# Runtime mode
RESEARCHER_AI_ENV=local

# Chroma vector store
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=researcher_ai_chunks
VECTOR_STORE_URL=http://localhost:8001

# SQLite metadata store
SQLITE_PATH=.local/researcher_ai.db
METADATA_DB_PATH=.local/researcher_ai.db

# Session state
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Trace storage
TRACE_STORE_PATH=.local/traces/execution_traces.jsonl

# LLM and embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=qwen2.5:32b
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ingestion defaults
PDF_PARSER=pymupdf
DEFAULT_TOP_K=10
DEFAULT_CLUSTER_MIN_SIZE=3
